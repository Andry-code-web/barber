---
// Footer.astro
const year = new Date().getFullYear();
---

<footer id="gallery" class="bg-zinc-950 border-t border-white/5">

  <!-- Main footer grid -->
  <div class="max-w-6xl mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

    <!-- Brand -->
    <div>
      <a href="#" class="font-display text-2xl tracking-[0.25em] text-white font-light block mb-6">
        LUMINA
      </a>
      <p class="text-zinc-600 text-sm leading-loose font-light mb-8 max-w-xs">
        La máxima expresión del cuidado masculino, donde el estilo clásico se encuentra con la precisión moderna.
      </p>
      <div class="flex gap-5">
        {[['IG', '#'], ['FB', '#'], ['TT', '#']].map(([label, href]) => (
          <a
            href={href}
            aria-label={label}
            class="text-xs tracking-widest text-zinc-600 hover:text-[#C9A84C] transition-colors duration-300"
          >
            {label}
          </a>
        ))}
      </div>
    </div>

    <!-- Contact -->
    <div>
      <h4 class="text-xs tracking-[0.3em] uppercase text-zinc-500 mb-6">Contacto</h4>
      <address class="not-italic">
        <p class="text-zinc-400 text-sm font-light mb-1">123 Avenida Elegancia</p>
        <p class="text-zinc-400 text-sm font-light mb-6">Distrito Financiero, 10001</p>
        <a href="tel:+15551234567" class="text-white text-lg font-display font-light hover:text-[#C9A84C] transition-colors block mb-1">
          +1 (555) 123-4567
        </a>
        <a href="mailto:reservas@luminabarbershop.com" class="text-zinc-500 text-xs hover:text-zinc-300 transition-colors">
          reservas@luminabarbershop.com
        </a>
      </address>
    </div>

    <!-- Hours -->
    <div>
      <h4 class="text-xs tracking-[0.3em] uppercase text-zinc-500 mb-6">Horario</h4>
      <ul class="space-y-3">
        {[
          ['Lun — Vie', '9:00 AM – 8:00 PM'],
          ['Sábado',    '9:00 AM – 6:00 PM'],
          ['Domingo',   'Cerrado'],
        ].map(([day, time]) => (
          <li class="flex justify-between items-baseline gap-4">
            <span class="text-zinc-600 text-xs tracking-widest uppercase">{day}</span>
            <span class={`text-sm font-light ${time === 'Cerrado' ? 'text-[#C9A84C]/60' : 'text-zinc-400'}`}>{time}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5 px-6 py-6">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-zinc-700 text-xs tracking-wide">© {year} Lumina Barbershop. Todos los derechos reservados.</p>
      <p class="text-zinc-700 text-xs tracking-wide">Hecho con precisión.</p>
    </div>
  </div>

</footer>
